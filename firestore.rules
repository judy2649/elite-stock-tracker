rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // Allow creation/syncing
      allow delete: if false;
    }

    match /custom_users/{userId} {
      allow read, write: if false; // Only backend (Admin SDK) should touch this
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In this specific app, staff can manage products
    }

    // --- Customers ---
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Staff can manage customers
    }

    // --- Sales ---
    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // For debt settling
      allow delete: if false;
    }
    
    // --- Expenses ---
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
